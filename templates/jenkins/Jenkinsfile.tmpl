// Generated by devsec — secure CI/CD pipeline for Jenkins (declarative).
// Steps are real and runnable. Configure credentials (e.g. SONAR_TOKEN,
// SONAR_HOST_URL) and the SLACK_CHANNEL / notification settings below.
pipeline {
    agent any

    options {
        timestamps()
    }

    environment {
        // Set these via Jenkins credentials / global config.
        SONAR_HOST_URL = "${env.SONAR_HOST_URL ?: ''}"
    }

    stages {
{{- range .Stages }}
        stage('{{ .Name }}') {
            steps {
{{ jenkinsSteps . $.Lang }}
            }
        }
{{- end }}
    }

    post {
        failure {
            echo "❌ Build failed: ${env.JOB_NAME} #${env.BUILD_NUMBER} (${env.BUILD_URL})"
            // Slack (requires the Slack Notification plugin + SLACK_CHANNEL):
            // slackSend channel: env.SLACK_CHANNEL ?: '#ci-alerts',
            //           color: 'danger',
            //           message: "❌ FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER} <${env.BUILD_URL}|open>"
            // Email fallback:
            mail to: 'devops@example.com',
                 subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                 body: "Build failed. See ${env.BUILD_URL}"
        }
        unstable {
            echo "⚠️ Build unstable: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
        }
        success {
            echo "✅ Build passed: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
        }
    }
}
