    displayName: {{ .Name }}
{{- if .DependsOn }}
    dependsOn:
{{- range .DependsOn }}
      - {{ . }}
{{- end }}
{{- end }}
    jobs:
      - job: {{ .ID }}
        displayName: {{ .Name }}
        steps:
          - checkout: self
{{- if .Tools }}
{{- range .Tools }}
          - script: echo "TODO: invoke {{ . }} here (devsec orchestrates, it does not bundle scanners)"
            displayName: Run {{ . }}
{{- end }}
{{- else }}
          - script: echo "TODO: implement {{ .Name }}"
            displayName: {{ .Name }}
{{- end }}
{{ end }}
